{
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "importOrder": [
    "<BUILTIN_MODULES>",
    "<TYPES>",
    "^@action/core/(.*)$",
    "^@action/github/(.*)$",
    "^@action/exec/(.*)$",
    "^@action/glob/(.*)$",
    "^@action/(.*)$",
    "<THIRD_PARTY_MODULES>",
    "^[./]"
  ],
  "plugins": ["@ianvs/prettier-plugin-sort-imports"]
}
